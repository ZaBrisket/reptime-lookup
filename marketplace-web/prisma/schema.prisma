generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  isAdmin   Boolean  @default(false)

  favorites Favorite[]
  reviews   Review[]
  deepLinks DeepLink[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  watchId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, watchId])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  targetType String   // "dealer" or "factory"
  targetId   String   // dealerId or factory code
  rating     Int
  text       String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model DeepLink {
  id        String   @id @default(cuid())
  watchId   String
  dealerId  String
  url       String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  // Only one deep link per dealer per watch
  @@unique([watchId, dealerId])
}
